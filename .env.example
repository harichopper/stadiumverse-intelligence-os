# StadiumVerse AI V2 - Environment Configuration
# "The Living Brain of the Stadium" - AI Native Stadium Intelligence Platform
# Copy this file to .env and update the values

# AI Configuration (Local Ollama - No API Keys Required)
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_TIMEOUT=30

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stadiumverse
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/stadiumverse

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Stadium Configuration
STADIUM_CAPACITY=80000
DIGITAL_FAN_COUNT=100
VOLUNTEER_COUNT=20

# AI Brain Configuration
AI_UPDATE_INTERVAL=5
PREDICTION_HORIZON=30
MAX_CONCURRENT_AGENTS=13
DEBATE_ENABLED=true
MEMORY_RETENTION_DAYS=365
FUTURE_BRANCH_COUNT=3

# Living Stadium Features
ENABLE_VOICE_COMMANDS=true
ENABLE_AI_DEBATE=true
ENABLE_FUTURE_BRANCHES=true
ENABLE_TIME_TRAVEL=true
ENABLE_COLLECTIVE_INTELLIGENCE=true
ENABLE_PERSONALITY_ENGINE=true
ENABLE_DIGITAL_TWIN_MEMORY=true
ENABLE_AI_STORYTELLER=true

# Voice Configuration (Offline)
VOICE_MODEL=whisper-base
TTS_VOICE=neural
SUPPORTED_LANGUAGES=["en","es","fr","ar","pt","hi","ja","de","zh"]

# Monitoring
LOG_LEVEL=INFO
METRICS_ENABLED=true

# CORS Origins (for development)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173"]

# Living Brain Memory Configuration
TWIN_MEMORY_UPDATE_INTERVAL=10
PERSONALITY_TRAIT_COUNT=12
EMOTION_STATE_COUNT=8
MEMORY_CATEGORIES=["visits","purchases","interactions","preferences","history"]

# Collective Intelligence Parameters
MIN_INTERVENTION_THRESHOLD=0.1
MAX_IMPACT_CALCULATION=true
ROI_ANALYSIS_ENABLED=true
CARBON_TRACKING=true

# Future Branch Engine
BRANCH_CALCULATION_DEPTH=6
CONFIDENCE_THRESHOLD=0.6
SCENARIO_SIMULATION_COUNT=16